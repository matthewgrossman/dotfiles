{
  "$schema": "https://opencode.ai/config.json",
  "lsp": false,
  "disabled_providers": ["opencode", "huggingface", "nvidia"],
  "provider": {
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp",
      "options": {
        "baseURL": "http://localhost:8080/v1"
      },
      "models": {
        "local": {
          "name": "Local Model"
        }
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "ollama",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3.6:27b": {
          "name": "Qwen 3.6 27B"
        },
        "hf.co/deepreinforce-ai/Ornith-1.0-9B-GGUF:latest": {
          "name": "Ornith 9B"
        }
      }
    }
  },
  "mcp": {
    "linear": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.linear.app/mcp"
    }
  }
}
