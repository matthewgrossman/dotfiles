// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "project_panel": {
    "dock": "right",
  },
  "outline_panel": {
    "dock": "right",
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "git": {
    "path_style": "file_path_first",
    "worktree_directory": "../worktrees",
  },
  "confirm_quit": true,
  "agent": {
    "dock": "left",
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "provider": "copilot_chat",
      "model": "claude-opus-4.8",
    },
    "favorite_models": [],
    "tool_permissions": {
      "default": "allow",
    },
    "model_parameters": [],
    "thinking_display": "always_collapsed",
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
    "github-copilot": {
      "type": "registry",
    },
    "opencode": {
      "default_config_options": {
        "effort": "medium",
        "model": "github-copilot/claude-opus-4.8"
      },
      "type": "registry",
    },
    "Amp": {
      "type": "custom",
      "command": "npx",
      "args": ["-y", "amp-acp"],
    },
  },
  "colorize_brackets": true,
  "diff_view_style": "unified",
  "edit_predictions": {
    "provider": "copilot",
  },
  "format_on_save": "off",
  "vim": {
    "toggle_relative_line_numbers": false,
  },
  "minimap": {
    "show": "never",
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "agent_buffer_font_size": 16.0,
  "base_keymap": "VSCode",
  "vim_mode": true,
  "ui_font_size": 17.0,
  "buffer_font_size": 15,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "One Dark",
  },
  "active_pane_modifiers": {
    "border_size": 1.0,
    "inactive_opacity": 0.8,
  },
  "terminal": {
    "font_family": "Hack Nerd Font",
  },
  "git_panel": {
    "tree_view": true,
    "dock": "right",
    "collapse_untracked_diff": true,
  },
  "languages": {
    "Python": {
      "language_servers": ["ty", "ruff"],
    },
  },
  "lsp": {
    "ty": {
      "binary": {
        "path": "~/.local/bin/ty",
        "arguments": ["server"],
      },
    },
  },
}
